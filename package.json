{
  "name": "@jasonbellz/gospel-library-mcp",
  "version": "2.0.0",
  "description": "MCP server for GitHub Copilot CLI — provides access to the Church of Jesus Christ Gospel Library (scriptures, General Conference talks, handbooks, and more)",
  "main": "dist/index.js",
  "bin": {
    "gospel-library-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gospel",
    "church",
    "lds",
    "scriptures",
    "copilot",
    "ai"
  ],
  "author": "jasonbellz",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonbellz/gospel-library-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "node-fetch": "^3.3.2",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
